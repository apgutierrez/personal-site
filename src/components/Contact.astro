<section id="contact">
  <div class="container">
    <hr />
    <span class="section-label">// contact</span>
    <h2 class="section-heading">Get in touch</h2>

    <div class="contact-header">
      <div>TO:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; <span>anyone curious</span></div>
      <div>FROM:&nbsp;&nbsp; <span>andrew gutierrez</span></div>
      <div>RE:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; <span>let's connect</span></div>
    </div>

    <div class="contact-links">
      <a
        href="https://www.linkedin.com/in/apgutierrez/"
        target="_blank"
        rel="noopener noreferrer"
        class="link-btn"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
        </svg>
        LinkedIn
      </a>

      <span class="link-btn link-btn--disabled" title="GitHub coming soon">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GitHub <span class="coming-soon">// soon</span>
      </span>
    </div>
  </div>
</section>

<style>
  .section-heading {
    margin-bottom: var(--space-8);
  }

  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .link-btn--disabled {
    opacity: 0.45;
    cursor: default;
    pointer-events: none;
  }

  .coming-soon {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-muted);
    margin-left: var(--space-1);
  }
</style>
