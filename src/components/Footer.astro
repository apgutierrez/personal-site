---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <hr />
    <p class="footer-text mono muted">// andrew gutierrez — {year}</p>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-12) 0 var(--space-8);
  }

  .footer hr {
    margin-bottom: var(--space-8);
  }

  .footer-text {
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    text-align: center;
  }
</style>
