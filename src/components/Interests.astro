---
const interests = [
  {
    label: 'Skiing',
    note: 'any mountain, any conditions',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m2 20 20-8"/><path d="m7 11 5 9"/><path d="M9.5 4.5a2 2 0 1 0 0-4 2 2 0 0 0 0 4z" fill="currentColor" stroke="none"/><path d="m14 5.5-2 3-2.5 2"/></svg>`,
  },
  {
    label: 'Hiking',
    note: 'the further out the better',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 20h18"/><path d="m8 20 4-12 4 12"/><path d="m9.5 14h5"/><path d="M16 6a2 2 0 1 0 0-4 2 2 0 0 0 0 4z" fill="currentColor" stroke="none"/></svg>`,
  },
  {
    label: 'Guitar',
    note: 'music has always been there',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m11 17-5 5"/><path d="m6 17 5 5"/><path d="m9.5 14.5-1 1"/><path d="M16.5 6 19 3.5 20.5 5 18 7.5"/><path d="M9.5 14.5C8 16 6.5 15.5 5 17c-1.5 1.5-1.5 3.5 0 5s3.5 1.5 5 0c1.5-1.5 1-3 2.5-4.5l5-5c1.5-1.5 2.5-1 4-2.5 1.5-1.5 1.5-3.5 0-5s-3.5-1.5-5 0c-1.5 1.5-1 3-2.5 4.5l-5 5z"/></svg>`,
  },
  {
    label: 'Climbing',
    note: 'just getting started',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a2 2 0 1 0 0 4 2 2 0 0 0 0-4z" fill="currentColor" stroke="none"/><path d="M9 9v6l-3 7"/><path d="m9 12 3 3 3-4"/><path d="m15 9-1 6 4 7"/></svg>`,
  },
  {
    label: 'Fatherhood',
    note: 'dad to two girls, outnumbered & fine with it',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
];
---

<section id="interests">
  <div class="container">
    <hr />
    <span class="section-label">// outside work</span>
    <h2 class="section-heading">What I'm into</h2>
    <div class="interests-grid">
      {interests.map((item) => (
        <div class="interest-item">
          <span class="interest-icon" set:html={item.icon} />
          <span class="interest-label">{item.label}</span>
          <span class="interest-note">{item.note}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-heading {
    margin-bottom: var(--space-10);
  }
</style>
