---
import InnerLayout from '../layouts/InnerLayout.astro';

const roles = [
  {
    years: '2022 – Present',
    lines: [
      {
        parts: [
          { text: 'Product - Adobe Express.', href: 'https://www.adobe.com/express/'}, 
          { text: ' Creative Systems', href: 'https://helpx.adobe.com/express/using/work-with-templates.html' },
        ],
      },
    ],
  },
  {
    years: '2018 – 2022',
    lines: [
      {
        parts: [
          { text: 'Product - Experience Platform.' },
          { text: ' Segment Match', href: 'https://experienceleague.adobe.com/docs/experience-platform/segmentation/ui/segment-match/overview.html' },
          { text: '.' },
        ],
      },
    ],
  },
  {
    years: '2014 – 2018',
    lines: [
      {
        parts: [
          { text: 'Consulting. Clients: American Express, NFL, T-Mobile & more.' },
        ],
      },
    ],
  },
];
---

<InnerLayout title="Work — Andrew Gutierrez" description="Career history.">
  <div class="resume">
    {roles.map((role) => (
      <div class="role">
        <span class="years mono muted">{role.years}</span>
        <p class="role-line">
          {role.lines[0].parts.map((part) =>
            part.href
              ? <a href={part.href} target="_blank" rel="noopener">{part.text}</a>
              : <span>{part.text}</span>
          )}
        </p>
      </div>
    ))}
  </div>
</InnerLayout>

<style>
  .resume {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    padding-top: var(--space-8);
  }

  .role {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .years {
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
  }

  .role-line {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-ink);
    max-width: 480px;
  }

  .role-line a {
    color: var(--color-ink);
    text-decoration-color: var(--color-accent);
    text-underline-offset: 3px;
    font-weight: 400;
  }

  .role-line a:hover {
    color: var(--color-accent);
  }

  .role-line span {
    color: var(--color-muted);
  }
</style>
