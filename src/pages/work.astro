---
import InnerLayout from '../layouts/InnerLayout.astro';
import { getCollection } from 'astro:content';
import WorkCard from '../components/WorkCard.astro';

const entries = await getCollection('work');
const sorted = entries.sort((a, b) => a.data.order - b.data.order);
---

<InnerLayout title="Work — Andrew Gutierrez" description="Career highlights and product work.">
  <h1 class="page-title">Work</h1>
  <p class="page-intro">
    Enterprise SaaS and consulting — mostly figuring out what people actually need
    versus what they asked for.
  </p>

  <div class="work-grid">
    {sorted.map((entry) => (
      <WorkCard
        label={entry.data.label}
        title={entry.data.title}
        period={entry.data.period}
        bullets={entry.data.bullets}
        tags={entry.data.tags}
      />
    ))}
  </div>
</InnerLayout>

<style>
  .page-title {
    font-size: var(--text-3xl);
    font-weight: 300;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-4);
  }

  .page-intro {
    color: var(--color-muted);
    max-width: 520px;
    margin-bottom: var(--space-12);
    line-height: 1.75;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  @media (max-width: 640px) {
    .work-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
